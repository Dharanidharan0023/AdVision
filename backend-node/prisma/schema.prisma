// Prisma schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("ROLE_ADMIN")
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  imageUrl  String?
  videoUrl  String?
  videoId   String?
  featured    Boolean  @default(false)
  slug        String?  @unique
  category    String?
  tags        String?
  status      String   @default("Draft")
  publishDate DateTime?

  // ✅ Prisma handles timestamps automatically
  createdAt DateTime @default(now())
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  status      String   @default("In Progress")
  category    String   @default("AdVision")
  imageUrl        String?
  videoLink       String?
  tags            String?
  websiteUrl      String?
  apkUrl          String?
  githubUrl       String?
  technologies    String?
  screenshots     String?
  plannedFeatures String?
  releaseDate     DateTime?
  createdAt   DateTime @default(now())
}

model HomeSection {
  id          Int      @id @default(autoincrement())
  sectionName String   @unique
  content     String
}

model About {
  id              Int      @id @default(autoincrement())
  title           String   @default("The Studio")
  subtitle        String   @default("Our Creative Journey")
  tagsLine        String?  @default("All glory to God")
  ourStoryTitle   String?  @default("Our Story")
  description     String   @default("Describe your studio journey here...")
  subscribersCount String? @default("1.09K+")
  videosCount      String? @default("105+")
  viewsCount       String? @default("274K+")
  communityText    String? @default("Rising")
  brandsList       String? 
  joinTitle        String? @default("Join the Movement")
  joinYoutubeLink  String? @default("https://youtube.com/@dharanixstudio")
  joinInstagramLink String? @default("https://www.instagram.com/visionofad")
  imageUrl        String?
  metaTitle       String?
  metaDescription String?
  keywords        String?
  updatedAt       DateTime @updatedAt
}

model ContactPage {
  id                Int      @id @default(autoincrement())
  pageTitle         String   @default("Contact")
  email             String   @default("support@dharanixstudio.com")
  phone             String   @default("+91 98765 43210")
  address           String   @default("Dharanidharan Studio, Chennai, India")
  googleMapUrl      String?
  businessHours     String?
  socialLinks       String?
  contactFormEnabled Boolean  @default(true)
  contactFormNote   String?
  updatedAt         DateTime @updatedAt
}

model FeaturedVideo {
  id           Int      @id @default(autoincrement())
  title        String
  videoUrl     String
  thumbnailUrl String?
  description  String?
  displayOrder Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
