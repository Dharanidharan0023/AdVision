// Prisma schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("ROLE_ADMIN")
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  imageUrl  String?
  videoUrl  String?
  videoId   String?
  featured  Boolean  @default(false)

  // ✅ Prisma handles timestamps automatically
  createdAt DateTime @default(now())
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  status      String   // Planned | In Progress | Completed
  imageUrl    String?
}

model HomeSection {
  id          Int      @id @default(autoincrement())
  sectionName String   @unique
  content     String
}

model About {
  id              Int      @id @default(autoincrement())
  title           String   @default("About AdVision")
  subtitle        String   @default("Our Creative Journey")
  description     String   @default("Describe your studio journey here...")
  imageUrl        String?
  experienceYears Int      @default(0)
  updatedAt       DateTime @updatedAt
}

model Story {
  id          Int       @id @default(autoincrement())
  title       String
  summary     String
  genre       String
  coverUrl    String?
  author      String    @default("Anonymous")
  status      String    @default("Ongoing")
  featured    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  chapters    Chapter[]
}

model Chapter {
  id          Int      @id @default(autoincrement())
  storyId     Int
  title       String
  content     String
  chapterNo   Int
  createdAt   DateTime @default(now())
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
}
