# Backend Environment Variables
# Create a .env file and add these variables

# Server configuration
PORT=3001
FRONTEND_URL=https://your-frontend-domain.vercel.app # Comma separated list for CORS

# Security
JWT_SECRET=your_super_secret_jwt_key_here

# Database
# If using Render's PostgreSQL, paste the Internal DB URL here
DATABASE_URL="postgresql://user:password@hostname:5432/dbname?schema=public"
